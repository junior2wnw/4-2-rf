{
  "name": "trustlink-kernel",
  "version": "0.1.0",
  "type": "module",
  "description": "A small universal kernel for consent-based encrypted byte streams between trusted identities.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/junior2wnw/4-2-rf.git"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./platform/node": {
      "types": "./dist/platform/node-crypto.d.ts",
      "default": "./dist/platform/node-crypto.js"
    }
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.json",
    "check": "pnpm language && pnpm typecheck && pnpm test && pnpm build",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "language": "node --import tsx scripts/check-language.ts",
    "prepack": "pnpm check",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "byte-stream",
    "pairing",
    "trust",
    "e2e",
    "transport-agnostic"
  ],
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
