{
  "name": "trustlink-kernel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A small universal kernel for consent-based encrypted byte streams between trusted identities.",
  "exports": {
    ".": "./dist/index.js",
    "./platform/node": "./dist/platform/node-crypto.js"
  },
  "bin": {
    "trustlink": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "pnpm language && pnpm typecheck && pnpm test && pnpm build",
    "demo": "pnpm build && node dist/cli.js demo",
    "dev": "node --import tsx src/cli.ts demo",
    "doctor": "pnpm build && node dist/cli.js doctor",
    "language": "node --import tsx scripts/check-language.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "byte-stream",
    "pairing",
    "trust",
    "e2e",
    "transport-agnostic"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
